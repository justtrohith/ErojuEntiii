# Gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash

# Meal planner system prompt (optional — if unset, built-in default with components[] is used)
# Single line with \n for newlines (works on Render/Cloud Run env vars):
# MEAL_PROMPT=You are ErojuEntiii.\nSuggest ONE Indian plate with components[]...
#
# Leave MEAL_PROMPT unset locally to use app/prompts/default_meal_prompt.txt
# MEAL_PROMPT=

# Firebase
FIREBASE_PROJECT_ID=erojuentiii

# Local only — path to service account JSON file:
FIREBASE_CREDENTIALS_PATH=./erojuentiii-firebase-adminsdk-fbsvc-53b519dfe0.json

# Render / Cloud Run only — paste minified JSON on ONE line (do not use PATH there):
# FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"erojuentiii",...}

# API
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=*

# Telegram bot (optional — dev only)
TELEGRAM_BOT_TOKEN=
