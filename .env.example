# Gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash

# Meal planner system prompt (optional text — if unset, built-in default is used)
# Single line with \n for newlines (works on Render/Cloud Run env vars):
# MEAL_PROMPT=You are ErojuEntiii.\nSuggest ONE meal.\nRespond with JSON only...
#
# Or multiline in .env using quotes:
MEAL_PROMPT="You are ErojuEntiii, a helpful meal planner for Indian home cooking.
Suggest ONE specific meal that fits the constraints.
Prefer simple, practical recipes using pantry items when possible.
Respond with JSON only, no markdown fences, using this schema:
{
  \"name\": \"meal name\",
  \"description\": \"one sentence\",
  \"ingredients\": [\"item1\", \"item2\"],
  \"steps\": [\"step1\", \"step2\"],
  \"macros_estimate\": {\"calories\": 450, \"protein_g\": 30, \"carbs_g\": 40, \"fat_g\": 15},
  \"time_minutes\": 25,
  \"uses_pantry\": [\"items from pantry used\"]
}"

# Firebase
FIREBASE_PROJECT_ID=erojuentiii
FIREBASE_CREDENTIALS_PATH=./erojuentiii-firebase-adminsdk-fbsvc-53b519dfe0.json
# Or paste JSON for cloud deploy (Render, Cloud Run):
# FIREBASE_CREDENTIALS_JSON={"type":"service_account",...}

# API
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=*

# Telegram bot (optional — dev only)
TELEGRAM_BOT_TOKEN=
